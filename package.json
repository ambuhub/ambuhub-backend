{
  "name": "ambuhub-backend",
  "version": "1.0.0",
  "description": "Ambulance service",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "build:clean": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "migrate:country-codes": "ts-node --transpile-only src/scripts/migrate-country-to-alpha2.ts",
    "migrate:patient-to-client": "ts-node --transpile-only src/scripts/migrate-patient-role-to-client.ts",
    "migrate:order-line-seller-user-id": "ts-node --transpile-only src/scripts/migrate-order-line-seller-user-id.ts",
    "migrate:listing-types-sale-hire-book": "ts-node --transpile-only src/scripts/migrate-listing-types-sale-hire-book.ts",
    "migrate:dept-ambulance-maintenance-to-servicing": "ts-node --transpile-only src/scripts/migrate-department-ambulance-maintenance-to-servicing.ts",
    "seed:orders-2026-provider": "ts-node --transpile-only src/scripts/seed-provider-orders-2026.ts",
    "migrate:hire-stock-pricing": "ts-node --transpile-only src/scripts/migrate-hire-stock-and-pricing-by-category.ts",
    "migrate:hire-location-return": "ts-node --transpile-only src/scripts/migrate-hire-location-and-return-window.ts",
    "backfill:hire-return-notification-schedules": "ts-node --transpile-only src/scripts/backfill-hire-return-notification-schedules.ts"
  },
  "keywords": [
    "Ambulance",
    "medical",
    "emergency"
  ],
  "author": "Brivnet",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "country-state-city": "^3.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "world-countries": "^5.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
